# ── MODE CLOUD (shared, semua orang lihat data sama) ──────────────
# Daftar gratis di https://jsonbin.io, buat sebuah Bin dengan isi awal: {}
# Lalu isi Bin ID dan Master Key dari dashboard akun kamu.
# Jika kosong, aplikasi berjalan dalam Mode Lokal (localStorage per browser).

VITE_JSONBIN_BIN_ID=
VITE_JSONBIN_API_KEY=

# ── ADMIN ─────────────────────────────────────────────────────────
# Username yang akan otomatis jadi admin saat pertama kali signup.
# Ganti dengan username admin kamu sendiri.
# Default jika kosong: 'admin'
VITE_ADMIN_USERNAME=admin
